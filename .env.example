# ===========================================
# Spain Aikikai Admin - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_password_here
MONGO_DB_NAME=spainaikikai

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend API URL (the URL where the backend is accessible from the browser)
# For production, use your actual domain: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# Optional: Logfire monitoring
LOGFIRE_TOKEN=

# ===========================================
# Dokploy Deployment Notes
# ===========================================
# 1. In Dokploy, create a new "Compose" application
# 2. Point to your git repository
# 3. Set the docker-compose file path to: docker-compose.yml
# 4. Add these environment variables in Dokploy's UI
# 5. Configure domains for frontend and backend services
